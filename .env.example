# DagsHub (MLflow + DVC remote)
DAGSHUB_USER=seu_usuario
DAGSHUB_REPO=seu_repositorio
DAGSHUB_TOKEN=seu_token

# Opcional: URI MLflow (default models:/DiabetesClassifier@production)
# MLFLOW_MODEL_URI=models:/DiabetesClassifier/latest

# Supabase — obrigatório para python3 -m src.ingestion (use service_role para upload)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=sua_service_role
# Nome da tabela com as mesmas colunas do Pima Indians Diabetes
SUPABASE_DIABETES_TABLE=diabetes
